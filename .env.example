# Copy file này thành .env rồi sửa lại theo máy của bạn.
PORT=3000

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=khanhpaintdealerdatabase
DB_CONNECTION_LIMIT=10

# Tối thiểu 32 ký tự. Không dùng chuỗi ví dụ này khi triển khai thật.
JWT_SECRET=replace_this_with_a_random_secret_at_least_32_chars
JWT_EXPIRES_IN=2h
